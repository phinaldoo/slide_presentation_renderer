# Slide renderer environment defaults

# Deployment environment name: development | staging | production
ENVIRONMENT=development

# Public port of nginx reverse proxy
NGINX_PORT=8080

# Development mode (enables docs and bypasses docs API key gate)
DEVELOPMENT_MODE=false

# FastAPI docs/openapi exposure (set true only for debugging)
ENABLE_DOCS=false

# Allow startup with production guardrail violations.
# Keep false in production unless you are intentionally accepting the risk.
ALLOW_INSECURE_PRODUCTION_CONFIGURATION=false

# Trusted hosts for FastAPI middleware
# Examples:
#   ALLOWED_HOSTS=renderer.example.com
#   ALLOWED_HOSTS=renderer.example.com,www.renderer.example.com
ALLOWED_HOSTS=*

# API key authentication
API_KEY_AUTH_ENABLED=true
# Comma-separated list for key rotation (all keys must be >=16 chars).
# Required: set to one or more real secrets before starting the stack.
# Example generation: openssl rand -base64 48
API_KEYS=

# Max time for one render request in seconds
RENDER_TIMEOUT_SECONDS=180

# Max time to wait for a free render worker slot before returning 429
RENDER_QUEUE_TIMEOUT_MS=500

# Max page navigation/load timeout used by Playwright
PAGE_LOAD_TIMEOUT_MS=30000

# Max number of render jobs running at once
MAX_CONCURRENT_RENDERS=2

# Max accepted HTTP request body size in bytes
MAX_REQUEST_BODY_BYTES=180000000

# Max number of characters in html request field
MAX_HTML_CHARS=2000000

# Max number of entries in input_files
MAX_INPUT_FILES=32

# Max bytes for one input file after base64 decoding
MAX_ASSET_BYTES=25000000

# Max total bytes of all decoded input files combined
MAX_TOTAL_ASSET_BYTES=120000000
